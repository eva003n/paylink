{
  "name": "paylink",
  "private": true,
  "version": "1.0.0",
  "description": "Send clients a payment link, trigger M-Pesa STK, and generate instant PDF receipts.",
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "stop:backend": "pnpm --filter backend stop",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:shared": "pnpm --filter @paylink/shared dev ",
    "start:dev": "pnpm --filter backend start:dev",
    "build:shared": "pnpm --filter @paylink/shared build",
    "build": "pnpm build:shared && pnpm --filter backend build && pnpm --filter frontend build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "Node",
    "Express",
    "REST API",
    "Background jobs",
    "Payments"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "zod": "^4.3.6"
  }
}